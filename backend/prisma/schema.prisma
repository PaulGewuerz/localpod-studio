generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String        @id @default(uuid())
  name             String
  megaphoneShowId  String?
  megaphoneRssUrl  String?
  defaultVoiceId   String?
  createdAt        DateTime      @default(now())
  users                User[]
  shows                Show[]
  subscription         Subscription?
  pronunciationRules   PronunciationRule[]
  defaultVoice         Voice?        @relation(fields: [defaultVoiceId], references: [id])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Show {
  id             String       @id @default(uuid())
  name           String
  description    String?
  coverArtUrl    String?
  author         String?
  category            String?
  directoryStatuses   Json?
  createdAt           DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  episodes       Episode[]
}

model Voice {
  id              String         @id @default(uuid())
  name            String
  elevenLabsId    String         @unique
  description     String?
  previewUrl      String?
  episodes        Episode[]
  orgsDefault     Organization[]
}

model Episode {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  scriptText         String?   // normalized text sent to ElevenLabs
  paragraphMeta      String?   // JSON: [{ order, text, timeStart, timeEnd }]
  audioUrl           String?
  // Valid values: draft | approved | published | scheduled
  status             String    @default("draft")
  publishedUrl       String?
  megaphoneEpisodeId String?
  characterCount     Int?
  scheduledAt        DateTime?
  createdAt          DateTime  @default(now())
  showId             String
  show               Show      @relation(fields: [showId], references: [id])
  voiceId            String?
  voice              Voice?    @relation(fields: [voiceId], references: [id])
}

model PronunciationRule {
  id             String       @id @default(uuid())
  word           String
  pronunciation  String
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, word])
}

model Subscription {
  id                   String       @id @default(uuid())
  status               String       @default("trial")
  plan                 String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime     @default(now())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id])
}
