generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String        @id @default(uuid())
  name             String
  defaultVoiceId   String?
  createdAt        DateTime      @default(now())
  users                User[]
  shows                Show[]
  subscription         Subscription?
  pronunciationRules   PronunciationRule[]
  adCampaigns          AdCampaign[]
  defaultVoice         Voice?        @relation(fields: [defaultVoiceId], references: [id])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  onboardedAt    DateTime?    // set when the user finishes (or skips) the product tour
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Show {
  id                  String       @id @default(uuid())
  name                String
  description         String?
  coverArtUrl         String?
  author              String?
  category            String?
  directoryStatuses   Json?
  adMarkerDefaults    String?      // JSON: { preRoll: bool, postRoll: bool, midRoll: number[] }
  megaphoneShowId     String?
  megaphoneRssUrl     String?
  feedUrl             String?      // resolved source URL the poller hits (feed/sitemap/homepage)
  sourceType          String?      // how to discover articles: rss | sitemap | scrape (null = rss)
  automationEnabled   Boolean      @default(false)
  automationVoiceId   String?
  automationIntervalDays Int?      // generate a digest episode every N days (1–8)
  automationStartAt   DateTime?    // first scheduled run
  automationNextRunAt DateTime?    // poller's "is this show due?" clock
  automationLastRunAt DateTime?    // last time a digest run fired
  automationAdSelections Json?     // { preRollCampaignId, postRollCampaignId, midRollCampaignIds: [] }
  createdAt           DateTime     @default(now())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  episodes            Episode[]
  automationVoice     Voice?       @relation("ShowAutomationVoice", fields: [automationVoiceId], references: [id])
  ingestedArticles    IngestedArticle[]
}

model Voice {
  id              String         @id @default(uuid())
  name            String
  elevenLabsId    String         @unique
  description     String?
  previewUrl      String?
  episodes        Episode[]
  orgsDefault     Organization[]
  automationShows Show[]         @relation("ShowAutomationVoice")
}

// Tracks feed items seen by the automatic episode flow so each article is only generated once.
model IngestedArticle {
  id        String   @id @default(uuid())
  guid      String   // feed item guid, falls back to link
  url       String?
  title     String?
  // pending | generated | failed | skipped
  status    String   @default("pending")
  error     String?
  episodeId String?
  createdAt DateTime @default(now())
  showId    String
  show      Show     @relation(fields: [showId], references: [id])

  @@unique([showId, guid])
}

model Episode {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  scriptText         String?   // normalized text sent to ElevenLabs
  paragraphMeta      String?   // JSON: [{ order, text, timeStart, timeEnd }]
  audioUrl           String?
  // Valid values: draft | approved | published | scheduled
  status             String    @default("draft")
  publishedUrl       String?
  megaphoneEpisodeId String?
  characterCount     Int?
  deletedAt          DateTime?
  adMarkers          String?   // JSON: { preRoll: bool, postRoll: bool, midRoll: number[] }
  adAssignments      String?   // JSON: [{ campaignId, type, insertAt? }] — campaigns to stitch at publish
  scheduledAt        DateTime?
  createdAt          DateTime  @default(now())
  showId             String
  show               Show      @relation(fields: [showId], references: [id])
  voiceId            String?
  voice              Voice?    @relation(fields: [voiceId], references: [id])
}

model PronunciationRule {
  id             String       @id @default(uuid())
  word           String
  pronunciation  String
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, word])
}

model AdCampaign {
  id             String       @id @default(uuid())
  name           String
  audioUrl       String?
  type           String       // pre-roll | mid-roll | post-roll
  status         String       @default("active")
  startDate      DateTime?
  endDate        DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Subscription {
  id                   String       @id @default(uuid())
  status               String       @default("trial")
  plan                 String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime     @default(now())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id])
}
